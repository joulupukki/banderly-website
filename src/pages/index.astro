    <script>
      // Intersection Observer for scroll-reveal animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px'
      });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Show/hide sticky nav based on hero visibility
      const nav = document.querySelector('.sticky-nav');
      const hero = document.querySelector('.hero');
      const navObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            nav.classList.remove('visible');
          } else {
            nav.classList.add('visible');
          }
        });
      }, { threshold: 0 });
      navObserver.observe(hero);

      // ─── Interactive Web Demo ───
      (function() {
        const songList = document.getElementById('demo-song-list');
        const webDemo = document.getElementById('web-demo');
        if (!songList || !webDemo) return;

        // Save original song order for reset
        const originalOrder = [...songList.querySelectorAll('.demo-song-row')];

        // Auto-animate on scroll in, reset on scroll out
        let hasAutoAnimated = false;
        let animTimeout = null;
        const demoObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !hasAutoAnimated) {
              hasAutoAnimated = true;
              animTimeout = setTimeout(() => autoAnimate(), 900);
            } else if (!entry.isIntersecting && hasAutoAnimated) {
              // Only reset if scrolled back up (section is below viewport)
              const rect = webDemo.getBoundingClientRect();
              if (rect.top > 0) {
                hasAutoAnimated = false;
                if (animTimeout) { clearTimeout(animTimeout); animTimeout = null; }
                songList.querySelectorAll('.demo-song-row').forEach(r => {
                  r.classList.remove('demo-animating', 'demo-lifted', 'demo-dragging', 'demo-drag-over');
                  r.style.transform = '';
                });
                originalOrder.forEach(r => songList.appendChild(r));
              }
            }
          });
        }, { threshold: 0.35 });
        demoObserver.observe(webDemo);

        function autoAnimate() {
          const rows = songList.querySelectorAll('.demo-song-row');
          if (rows.length < 3) return;

          const row0 = rows[0];
          const row1 = rows[1];
          const row2 = rows[2];
          const gap = parseFloat(getComputedStyle(songList).gap) || 0;
          const rowHeight = row0.offsetHeight + gap;

          [row0, row1, row2].forEach(r => r.classList.add('demo-animating'));

          row0.classList.add('demo-lifted');
          row0.style.transform = 'translateY(' + (rowHeight * 2) + 'px)';
          row1.style.transform = 'translateY(-' + rowHeight + 'px)';
          row2.style.transform = 'translateY(-' + rowHeight + 'px)';

          setTimeout(() => {
            [row0, row1, row2].forEach(r => {
              r.classList.remove('demo-animating', 'demo-lifted');
              r.style.transform = '';
            });
            songList.insertBefore(row1, row0);
            songList.insertBefore(row2, row0);
          }, 600);
        }

        // Drag and drop
        let dragRow = null;

        songList.addEventListener('dragstart', (e) => {
          const row = e.target.closest('.demo-song-row');
          if (!row) return;
          dragRow = row;
          row.classList.add('demo-dragging');
          e.dataTransfer.effectAllowed = 'move';
        });

        songList.addEventListener('dragend', (e) => {
          const row = e.target.closest('.demo-song-row');
          if (row) row.classList.remove('demo-dragging');
          songList.querySelectorAll('.demo-drag-over').forEach(r => r.classList.remove('demo-drag-over'));
          dragRow = null;
        });

        songList.addEventListener('dragover', (e) => {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          const target = e.target.closest('.demo-song-row');
          if (!target || target === dragRow) return;
          songList.querySelectorAll('.demo-drag-over').forEach(r => r.classList.remove('demo-drag-over'));
          target.classList.add('demo-drag-over');
        });

        songList.addEventListener('dragleave', (e) => {
          const target = e.target.closest('.demo-song-row');
          if (target) target.classList.remove('demo-drag-over');
        });

        songList.addEventListener('drop', (e) => {
          e.preventDefault();
          const target = e.target.closest('.demo-song-row');
          if (!target || !dragRow || target === dragRow) return;
          const targetRect = target.getBoundingClientRect();
          const midY = targetRect.top + targetRect.height / 2;
          if (e.clientY < midY) {
            songList.insertBefore(dragRow, target);
          } else {
            songList.insertBefore(dragRow, target.nextSibling);
          }
          target.classList.remove('demo-drag-over');
        });

        // Touch drag support
        let touchRow = null;
        let touchClone = null;
        let touchOffsetY = 0;

        songList.addEventListener('touchstart', (e) => {
          const handle = e.target.closest('.demo-drag');
          if (!handle) return;
          const row = handle.closest('.demo-song-row');
          if (!row) return;
          touchRow = row;
          const rect = row.getBoundingClientRect();
          touchOffsetY = e.touches[0].clientY - rect.top;

          touchClone = row.cloneNode(true);
          touchClone.style.cssText = 'position:fixed;left:' + rect.left + 'px;top:' + rect.top + 'px;width:' + rect.width + 'px;z-index:9999;opacity:0.9;box-shadow:0 6px 20px rgba(0,0,0,0.15);border-color:#1d4ed8;pointer-events:none;';
          document.body.appendChild(touchClone);
          row.classList.add('demo-dragging');
          e.preventDefault();
        }, { passive: false });

        songList.addEventListener('touchmove', (e) => {
          if (!touchRow || !touchClone) return;
          e.preventDefault();
          const y = e.touches[0].clientY;
          touchClone.style.top = (y - touchOffsetY) + 'px';
          songList.querySelectorAll('.demo-drag-over').forEach(r => r.classList.remove('demo-drag-over'));
          for (const r of songList.querySelectorAll('.demo-song-row')) {
            if (r === touchRow) continue;
            const rect = r.getBoundingClientRect();
            if (y > rect.top && y < rect.bottom) { r.classList.add('demo-drag-over'); break; }
          }
        }, { passive: false });

        songList.addEventListener('touchend', () => {
          if (!touchRow) return;
          const target = songList.querySelector('.demo-drag-over');
          if (target && target !== touchRow) {
            const rect = target.getBoundingClientRect();
            const lastY = touchClone ? parseFloat(touchClone.style.top) + touchOffsetY : 0;
            if (lastY < rect.top + rect.height / 2) {
              songList.insertBefore(touchRow, target);
            } else {
              songList.insertBefore(touchRow, target.nextSibling);
            }
          }
          touchRow.classList.remove('demo-dragging');
          songList.querySelectorAll('.demo-drag-over').forEach(r => r.classList.remove('demo-drag-over'));
          if (touchClone) { touchClone.remove(); touchClone = null; }
          touchRow = null;
        });
      })();
    </script>
